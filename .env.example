# SimFly OS Environment Configuration
# Copy this file to .env and fill in your values

# Required: Google Gemini API Key
GOOGLE_API_KEY=your_gemini_api_key_here

# Required: Admin WhatsApp Number (with country code, e.g., 923123456789)
ADMIN_NUMBER=923XXXXXXXXX

# Required: Render External URL (for dashboard access)
# Format: https://your-service-name.onrender.com
RENDER_URL=https://your-service-name.onrender.com

# Optional: Port (Render sets this automatically)
PORT=3000
