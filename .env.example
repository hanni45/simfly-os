# SimFly OS v5.0 - Environment Configuration
# Copy this file to .env and fill in your values

# ═══════════════════════════════════════════════════════════════
# REQUIRED API KEYS
# ═══════════════════════════════════════════════════════════════

# Groq API Key (Primary AI) - Get from console.groq.com
GROQ_API_KEY=gsk_your_groq_key_here

# Gemini API Keys (Vision for screenshots) - Get from makersuite.google.com
# Add multiple keys for rotation
GEMINI_API_KEY_1=your_gemini_key_1
GEMINI_API_KEY_2=your_gemini_key_2
GEMINI_API_KEY_3=your_gemini_key_3

# ═══════════════════════════════════════════════════════════════
# FIREBASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════

# Get from Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# Download private key from Firebase, replace newlines with \n
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com

# ═══════════════════════════════════════════════════════════════
# ADMIN CONFIGURATION
# ═══════════════════════════════════════════════════════════════

# Admin WhatsApp number (Pakistan format: 923001234567)
ADMIN_NUMBER=923001234567

# ═══════════════════════════════════════════════════════════════
# BOT SETTINGS
# ═══════════════════════════════════════════════════════════════

# Bot mode: public | test | maintenance
BOT_MODE=public

# Response delay in ms (typing simulation)
RESPONSE_DELAY=1000

# Enable/disable AI (fallback to templates if false)
USE_AI=true

# Max conversation history per customer (memory optimization)
MAX_HISTORY=20

# ═══════════════════════════════════════════════════════════════
# WEB SERVER SETTINGS
# ═══════════════════════════════════════════════════════════════

# Port for web dashboard (Railway sets this automatically)
PORT=3000

# ═══════════════════════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════════════════════

# Log level: error | warn | info | debug
LOG_LEVEL=info

# Log to file
LOG_TO_FILE=true
LOG_FILE_PATH=./logs/simfly.log

# ═══════════════════════════════════════════════════════════════
# OPTIONAL: EXTERNAL SERVICES
# ═══════════════════════════════════════════════════════════════

# Telegram bot token for admin alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
